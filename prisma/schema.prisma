generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AgentStatus {
  idle
  running
  waiting_approval
  blocked
  failed
  offline
}

enum HealthStatus {
  ok
  degraded
  failing
  unknown
}

enum ProjectStatus {
  active
  blocked
  submitted
  completed
  archived
}

enum TaskStatus {
  created
  classified
  planned
  waiting_approval
  queued
  claimed
  running
  tool_wait
  verifying
  blocked
  retry_scheduled
  needs_changes
  completed
  failed
  cancelled
  expired
  rolled_back
  archived
}

enum ApprovalStatus {
  pending
  approved_waiting_execution
  executing
  rejected
  needs_changes
  completed
  manual_handoff
}

enum ApprovalType {
  bounty_submission
  revenue_outreach
  wallet_kyc
  live_trading
  paid_action
  deploy
  public_disclosure
  other
}

enum RiskLevel {
  low
  medium
  high
  critical
}

enum ArtifactType {
  report
  poc
  csv
  decision_log
  discord_thread
  github_commit
  cron_output
  screenshot
  config_backup
  status_file
  other
}

enum PolicyAction {
  allow
  require_approval
  block
  require_manual_handoff
}

enum EventSeverity {
  info
  warning
  critical
}

enum CommandStatus {
  queued
  waiting_manual_handoff
  running
  completed
  failed
  cancelled
}

enum SystemScope {
  company
  crypto
  auth
  alpha
  personal
  infra
}

enum VerificationStatus {
  pending
  passed
  failed
  inconclusive
  not_required
}

enum RunStatus {
  queued
  running
  completed
  failed
  cancelled
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  role      String    @default("operator")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sessions  Session[]
  events    Event[]   @relation("EventActor")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Agent {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  status      AgentStatus  @default(idle)
  health      HealthStatus @default(unknown)
  heartbeatAt DateTime?
  currentTask String?
  systemScope SystemScope  @default(company)
  metadata    Json         @default("{}")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  tasks        Task[]
  artifacts    Artifact[]
  events       Event[]
  capabilities AgentCapability[]
  runs         Run[]
}

model AgentCapability {
  id                      String       @id @default(cuid())
  agentId                 String
  capabilityKey           String
  inputSchema             Json         @default("{}")
  outputSchema            Json         @default("{}")
  allowedTools            Json         @default("[]")
  maxRisk                 RiskLevel    @default(low)
  expectedArtifactType    ArtifactType @default(report)
  successCriteria         Json         @default("[]")
  failureModes            Json         @default("[]")
  rollbackOrManualHandoff String
  requiresApproval        Boolean      @default(false)
  avgCost                 Float        @default(0)
  avgDuration             Int          @default(0)
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  agent                   Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, capabilityKey])
  @@index([capabilityKey])
}

model Project {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String
  status      ProjectStatus @default(active)
  revenueType String?
  nextAction  String?
  blocker     String?
  systemScope SystemScope   @default(company)
  metadata    Json          @default("{}")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  tasks       Task[]
  approvals   Approval[]
  artifacts   Artifact[]
  events      Event[]
}

model Task {
  id                 String             @id @default(cuid())
  slug               String             @unique
  title              String
  status             TaskStatus         @default(queued)
  statusReason       String?
  planJson           Json               @default("{}")
  currentStep        String?
  attempt            Int                @default(0)
  maxAttempts        Int                @default(3)
  claimedBy          String?
  claimedAt          DateTime?
  heartbeatAt        DateTime?
  leaseExpiresAt     DateTime?
  idempotencyKey     String?
  traceId            String?
  systemScope        SystemScope        @default(company)
  verificationStatus VerificationStatus @default(pending)
  rollbackPlan       String?
  costEstimateUsd    Float              @default(0)
  costActualUsd      Float              @default(0)
  tokenInput         Int                @default(0)
  tokenOutput        Int                @default(0)
  riskLevel          RiskLevel          @default(low)
  summary            String?
  blocker            String?
  nextAction         String?
  agentId            String?
  projectId          String?
  parentTaskId       String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  agent              Agent?             @relation(fields: [agentId], references: [id])
  project            Project?           @relation(fields: [projectId], references: [id])
  parentTask         Task?              @relation("TaskParent", fields: [parentTaskId], references: [id])
  childTasks         Task[]             @relation("TaskParent")
  approvals          Approval[]
  artifacts          Artifact[]
  events             Event[]
  runs               Run[]
  verifications      Verification[]

  @@index([traceId])
  @@index([systemScope, status])
  @@index([claimedBy, leaseExpiresAt])
  @@index([verificationStatus, status])
}

model Approval {
  id              String         @id @default(cuid())
  externalKey     String?        @unique
  type            ApprovalType
  status          ApprovalStatus @default(pending)
  riskLevel       RiskLevel      @default(low)
  title           String
  summary         String
  decisionNote    String?
  manualReportId  String?
  requestedBy     String?
  systemScope     SystemScope    @default(company)
  traceId         String?
  rollbackPlan    String?
  projectId       String?
  taskId          String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  project         Project?       @relation(fields: [projectId], references: [id])
  task            Task?          @relation(fields: [taskId], references: [id])
  commandQueues   CommandQueue[]
  events          Event[]
}

model Artifact {
  id                String       @id @default(cuid())
  type              ArtifactType
  title             String
  path              String?
  url               String?
  repo              String?
  commitSha         String?
  diffHash          String?
  traceId           String?
  systemScope       SystemScope  @default(company)
  contentHash       String       @unique
  restricted        Boolean      @default(false)
  restrictionReason String?
  agentId           String?
  projectId         String?
  taskId            String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  agent             Agent?       @relation(fields: [agentId], references: [id])
  project           Project?     @relation(fields: [projectId], references: [id])
  task              Task?        @relation(fields: [taskId], references: [id])
  events            Event[]
}

model CommandQueue {
  id           String        @id @default(cuid())
  actionType   String
  status       CommandStatus @default(queued)
  riskLevel    RiskLevel     @default(low)
  traceId      String?
  systemScope  SystemScope   @default(company)
  payload      Json          @default("{}")
  result       Json?
  approvalId   String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  approval     Approval?     @relation(fields: [approvalId], references: [id])
  events       Event[]
}

model Policy {
  id          String       @id @default(cuid())
  actionType  String       @unique
  action      PolicyAction
  riskLevel   RiskLevel    @default(low)
  description String
  systemScope SystemScope  @default(company)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Event {
  id             String         @id @default(cuid())
  type           String
  severity       EventSeverity  @default(info)
  message        String
  traceId        String?
  systemScope    SystemScope    @default(company)
  metadata       Json           @default("{}")
  actorId        String?
  agentId        String?
  projectId      String?
  taskId         String?
  approvalId     String?
  artifactId     String?
  commandQueueId String?
  createdAt      DateTime       @default(now())
  actor          User?          @relation("EventActor", fields: [actorId], references: [id])
  agent          Agent?         @relation(fields: [agentId], references: [id])
  project        Project?       @relation(fields: [projectId], references: [id])
  task           Task?          @relation(fields: [taskId], references: [id])
  approval       Approval?      @relation(fields: [approvalId], references: [id])
  artifact       Artifact?      @relation(fields: [artifactId], references: [id])
  commandQueue   CommandQueue?  @relation(fields: [commandQueueId], references: [id])
}

model Run {
  id           String    @id @default(cuid())
  taskId       String?
  agentId      String?
  agentSlug    String
  profile      String
  model        String?
  status       RunStatus @default(running)
  traceId      String?
  systemScope  SystemScope @default(company)
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  inputTokens  Int       @default(0)
  outputTokens Int       @default(0)
  costUsd      Float     @default(0)
  latencyMs    Int       @default(0)
  metadata     Json      @default("{}")
  task         Task?     @relation(fields: [taskId], references: [id])
  agent        Agent?    @relation(fields: [agentId], references: [id])
  steps        Step[]

  @@index([traceId])
  @@index([taskId, status])
}

model Step {
  id            String    @id @default(cuid())
  runId         String
  index         Int
  kind          String
  status        RunStatus @default(running)
  inputSummary  String?
  outputSummary String?
  artifactPath  String?
  startedAt     DateTime  @default(now())
  endedAt       DateTime?
  run           Run       @relation(fields: [runId], references: [id], onDelete: Cascade)
  toolCalls     ToolCall[]
  modelCalls    ModelCall[]

  @@unique([runId, index])
}

model ToolCall {
  id         String    @id @default(cuid())
  stepId     String
  toolName   String
  riskLevel  RiskLevel @default(low)
  argsHash   String?
  outputHash String?
  durationMs Int       @default(0)
  status     RunStatus @default(completed)
  createdAt  DateTime  @default(now())
  step       Step      @relation(fields: [stepId], references: [id], onDelete: Cascade)
}

model ModelCall {
  id           String    @id @default(cuid())
  stepId       String
  provider     String?
  model        String
  inputTokens  Int       @default(0)
  outputTokens Int       @default(0)
  cacheTokens  Int       @default(0)
  costUsd      Float     @default(0)
  latencyMs    Int       @default(0)
  status       RunStatus @default(completed)
  createdAt    DateTime  @default(now())
  step         Step      @relation(fields: [stepId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String             @id @default(cuid())
  taskId     String
  verifier   String
  status     VerificationStatus
  checks     Json               @default("[]")
  evidence   Json               @default("{}")
  traceId    String?
  createdAt  DateTime           @default(now())
  task       Task               @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, status])
  @@index([traceId])
}

model Incident {
  id          String       @id @default(cuid())
  type        String
  severity    EventSeverity @default(warning)
  status      String       @default("open")
  title       String
  summary     String
  traceId     String?
  systemScope SystemScope  @default(company)
  taskId      String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model ScheduledRun {
  id          String       @id @default(cuid())
  jobId       String
  jobName     String?
  profile     String
  status      RunStatus
  failureClass String?
  traceId     String?
  systemScope SystemScope  @default(company)
  startedAt   DateTime     @default(now())
  endedAt     DateTime?
  metadata    Json         @default("{}")

  @@index([profile, status])
  @@index([failureClass])
}

model EvalResult {
  id          String      @id @default(cuid())
  taskId      String?
  agentSlug   String?
  dimensions  Json        @default("{}")
  traceId     String?
  systemScope SystemScope @default(company)
  createdAt   DateTime    @default(now())
}

model MemoryWrite {
  id          String      @id @default(cuid())
  target      String
  summary     String
  traceId     String?
  systemScope SystemScope @default(company)
  createdAt   DateTime    @default(now())
}
